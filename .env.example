# Required
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Polling interval in seconds (default: 3600 = 1 hour). Use 0 to run once and exit.
POLL_INTERVAL_SECONDS=3600

# Apple App Store
APPLE_APP_ID=          # numeric ID from the App Store URL: .../id564924168
APPLE_REGION=br        # br, us, pt, es, ...

# Google Play Store
PLAY_STORE_PACKAGE=    # package name, e.g. com.example.app
PLAY_STORE_LANG=pt     # pt, en, es, ...
PLAY_STORE_COUNTRY=br  # br, us, ...
